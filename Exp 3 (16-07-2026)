# Import necessary libraries
import pandas as pd
from sklearn.tree import DecisionTreeClassifier, plot_tree
from sklearn.preprocessing import LabelEncoder
import matplotlib.pyplot as plt


# 1. Create a Sample Dataset
print("--- 1. Original Dataset ---")
data = {
    'Outlook': ['Sunny', 'Sunny', 'Overcast', 'Rain', 'Rain', 'Rain', 'Overcast', 'Sunny', 'Sunny', 'Rain', 'Sunny', 'Overcast', 'Overcast', 'Rain'],
    'Temperature': ['Hot', 'Hot', 'Hot', 'Mild', 'Cool', 'Cool', 'Cool', 'Mild', 'Cool', 'Mild', 'Mild', 'Mild', 'Hot', 'Mild'],
    'Humidity': ['High', 'High', 'High', 'High', 'Normal', 'Normal', 'Normal', 'High', 'Normal', 'Normal', 'Normal', 'High', 'Normal', 'High'],
    'Wind': ['Weak', 'Strong', 'Weak', 'Weak', 'Weak', 'Strong', 'Strong', 'Weak', 'Weak', 'Weak', 'Strong', 'Strong', 'Weak', 'Strong'],
    'PlayTennis': ['No', 'No', 'Yes', 'Yes', 'Yes', 'No', 'Yes', 'No', 'Yes', 'Yes', 'Yes', 'Yes', 'Yes', 'No']
}
df = pd.DataFrame(data)
display(df)


# 2. Prepare the Data (Encode Categorical Features)
print("\n--- 2. Encoded Dataset ---")
le = LabelEncoder()
df_encoded = df.copy()

for column in df.columns:
    df_encoded[column] = le.fit_transform(df_encoded[column])
    if column == 'PlayTennis':
        play_tennis_classes = le.classes_

display(df_encoded)

X = df_encoded.drop('PlayTennis', axis=1)
y = df_encoded['PlayTennis']
feature_names = X.columns.tolist()
class_names = play_tennis_classes.tolist()

print(f"\nFeature names: {feature_names}")
print(f"Class names (PlayTennis): {class_names}")


# 3. Build the Decision Tree (ID3 Logic)
print("\n--- 3. Training Decision Tree ---")
id3_tree = DecisionTreeClassifier(criterion='entropy', random_state=42)
id3_tree.fit(X, y)
print("Decision Tree (ID3) model trained successfully!")


# 4. Visualize the Decision Tree
print("\n--- 4. Visualizing Decision Tree ---")
plt.figure(figsize=(20, 10))
plot_tree(id3_tree,
          feature_names=feature_names,
          class_names=class_names,
          filled=True, 
          rounded=True, 
          fontsize=10)
plt.title("ID3 Decision Tree for Play Tennis Dataset")
plt.show()


# 5. Classify a New Sample
print("\n--- 5. Classifying New Sample ---")
new_sample_data = {
    'Outlook': ['Sunny'],
    'Temperature': ['Cool'],
    'Humidity': ['High'],
    'Wind': ['Strong']
}
new_sample_df = pd.DataFrame(new_sample_data)
print("New Sample to Classify:")
display(new_sample_df)

encoded_new_sample = pd.DataFrame()
for col in feature_names:
    le_col = LabelEncoder()
    le_col.fit(df[col])
    encoded_new_sample[col] = le_col.transform(new_sample_df[col])

print("\nEncoded New Sample:")
display(encoded_new_sample)

prediction_encoded = id3_tree.predict(encoded_new_sample)
predicted_class = play_tennis_classes[prediction_encoded[0]]

print(f"\nPrediction for the new sample: {predicted_class}")
